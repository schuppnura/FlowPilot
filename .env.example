# FlowPilot Environment Configuration
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control

# Keycloak Admin Credentials (for bootstrap/development only)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Keycloak Service Account Client Secret
# Generate a strong secret for production: openssl rand -hex 32
KEYCLOAK_CLIENT_SECRET=changeme

# Demo User Password (for development/testing only)
DEMO_USER_PASSWORD=changeme
