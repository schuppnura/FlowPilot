[MASTER]
# Specify a configuration file.
# rcfile=

# Python code to execute, usually for sys.path manipulation such as
# pygtk.require().
init-hook='import sys; sys.path.append(".")'

# Add files or directories to the ignore list. They should be base names, not paths.
ignore=CVS

# Add files or directories matching the regex patterns to the ignore list.
ignore-patterns=

# List of module names for which member attributes should not be checked
ignored-modules=

# List of class names for which member attributes should not be checked
ignored-classes=

[MESSAGES CONTROL]
# Disable specific warnings
# E0401: import-error - Unable to import
# C0301: line-too-long - Line too long
# W0718: broad-exception-caught - Catching too general exception
# R0914: too-many-locals - Too many local variables
# R0913: too-many-arguments - Too many arguments
# C0114: missing-module-docstring - Code uses inline comments instead
# C0115: missing-class-docstring - Code uses inline comments instead
# C0116: missing-function-docstring - Code uses inline comments instead
disable=import-error,line-too-long,broad-exception-caught,too-many-locals,too-many-arguments,missing-module-docstring,missing-class-docstring,missing-function-docstring

[TYPECHECK]
# List of module names for which member attributes should not be checked
ignored-modules=utils

# Tells pylint to check shared-utils.py instead of utils.py
# Since utils.py will be copied into each Docker container, we ignore import errors
# and ensure shared-utils.py is the source of truth for linting
extension-pkg-whitelist=

[IMPORTS]
# Ignore imports that cannot be resolved (like utils which is copied at build time)
ignored-modules=utils
